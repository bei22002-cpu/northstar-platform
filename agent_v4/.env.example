# Cornerstone AI Agent v4 — Configuration
#
# Copy this file to .env and fill in your values.

# ── API Keys (supports up to 10 for automatic rotation) ──
ANTHROPIC_API_KEY_1=your-first-anthropic-api-key
ANTHROPIC_API_KEY_2=your-second-anthropic-api-key
# ANTHROPIC_API_KEY_3=...

# ── Workspace ──
WORKSPACE=./backend

# ── Model (opus | sonnet | haiku) ──
DEFAULT_MODEL=sonnet
MAX_TOKENS=8096

# ── Custom System Prompt (optional) ──
# Set inline or create agent_v4/system_prompt.txt
# SYSTEM_PROMPT=You are a helpful coding assistant...

# ── GitHub Integration (#3) ──
# Required for git_create_pr tool. Get a token at:
# https://github.com/settings/tokens (needs 'repo' scope)
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# ── Slack Bot (#9) ──
# Required for --slack mode. Create a Slack app at:
# https://api.slack.com/apps
# Bot needs: app_mentions:read, chat:write, im:history scopes
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# ── Linting (#8) ──
# Auto-detects ruff/flake8/eslint if installed.
# Override with custom commands:
LINT_COMMAND=
TYPECHECK_COMMAND=
