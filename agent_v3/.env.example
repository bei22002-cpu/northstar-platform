# Cornerstone AI Agent v3 — Configuration
#
# Copy this file to .env and fill in your Anthropic API key(s).
# Supports up to 10 keys for automatic rotation.

ANTHROPIC_API_KEY_1=your-first-anthropic-api-key
ANTHROPIC_API_KEY_2=your-second-anthropic-api-key
# ANTHROPIC_API_KEY_3=...

# Workspace path (default: ./backend relative to repo root)
WORKSPACE=./backend

# Default model: opus | sonnet | haiku
DEFAULT_MODEL=sonnet

# Max tokens per response
MAX_TOKENS=8096
