# NorthStar Platform — Backend Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# Database connection (SQLite used by default for local dev)
DATABASE_URL=sqlite:///./northstar.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://username:password@localhost/northstar_db

# JWT secrets — change these before deploying to production
JWT_SECRET=replace-me-with-a-strong-random-secret
JWT_REFRESH_SECRET=replace-me-with-a-different-strong-secret

# Outreach generation mode: "template" (default, no LLM) or "openai"
LLM_PROVIDER=template

# Required only when LLM_PROVIDER=openai
OPENAI_API_KEY=
