# Cornerstone AI Agent v5 — Jarvis Edition
# Copy this file to .env and fill in your values.

# ── Anthropic API keys (supports up to 10 for rotation) ──────────────
ANTHROPIC_API_KEY_1=your-anthropic-api-key-here
# ANTHROPIC_API_KEY_2=optional-second-key
# ANTHROPIC_API_KEY_3=optional-third-key

# ── OpenAI-compatible API (for vLLM, SGLang, LM Studio, etc.) ───────
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_BASE_URL=http://localhost:8080/v1

# ── Ollama (local inference) ─────────────────────────────────────────
# OLLAMA_HOST=http://localhost:11434

# ── Agent settings ───────────────────────────────────────────────────
# DEFAULT_ENGINE=auto          # auto | ollama | anthropic | openai
# DEFAULT_MODEL=               # Leave blank for auto-detection
# AGENT_TYPE=orchestrator      # simple | orchestrator | react

# ── Memory ───────────────────────────────────────────────────────────
# MEMORY_BACKEND=sqlite        # sqlite | vector | hybrid

# ── Workspace ────────────────────────────────────────────────────────
WORKSPACE=.

# ── Server ───────────────────────────────────────────────────────────
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000

# ── SaaS Platform ──────────────────────────────────────────────────
# JWT_SECRET=your-jwt-secret-here
# ADMIN_PASSWORD=your-admin-password-here
# PASSWORD_SALT=your-password-salt-here

# ── Stripe Billing ────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_your-secret-key-here
# STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
# Create products/prices at https://dashboard.stripe.com/products
# STRIPE_PRO_PRICE_ID=price_your-pro-price-id
# STRIPE_ENTERPRISE_PRICE_ID=price_your-enterprise-price-id
# SAAS_BASE_URL=http://localhost:8000
