# ── Cornerstone AI SaaS Platform ──────────────────────────
# Copy this file to .env and fill in your values.

# Secret key for JWT tokens (change this!)
SECRET_KEY=change-me-to-a-random-string

# SQLite database path
DATABASE_PATH=./agent_saas/data.db

# ── Anthropic API Keys ───────────────────────────────────
ANTHROPIC_API_KEY_1=your-first-anthropic-api-key
ANTHROPIC_API_KEY_2=your-second-anthropic-api-key

# Workspace for agent tools (relative to repo root)
WORKSPACE=./backend

# ── Stripe (optional — needed for paid plans) ────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create these in Stripe Dashboard > Products > Add Product
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── App Settings ─────────────────────────────────────────
APP_NAME=Cornerstone AI
APP_URL=http://localhost:8000
DEBUG=false
