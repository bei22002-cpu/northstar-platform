# ============================================================
# AI Provider — choose one (default: claude)
# ============================================================
# PROVIDER=claude       # Paid — uses Anthropic API keys below
# PROVIDER=openclaw     # FREE — uses OpenClaw Zero Token gateway
# PROVIDER=ollama       # FREE — runs models locally on your machine
# PROVIDER=gemini       # FREE tier — uses Google Gemini API
# PROVIDER=free         # FREE — chains Groq + Gemini + Cerebras + GitHub Models
PROVIDER=claude

# ============================================================
# Claude (Anthropic) — required when PROVIDER=claude
# ============================================================
# Add multiple API keys for automatic rotation.
# The agent will switch to the next key when one hits a rate limit.
ANTHROPIC_API_KEY_1=sk-ant-your-first-key-here
ANTHROPIC_API_KEY_2=sk-ant-your-second-key-here
ANTHROPIC_API_KEY_3=sk-ant-your-third-key-here

# Or use a single key (v1 compatible):
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================================
# OpenClaw Zero Token — required when PROVIDER=openclaw
# ============================================================
# Setup:
#   git clone https://github.com/linuxhsj/openclaw-zero-token
#   cd openclaw-zero-token && pnpm install
#   npx openclaw setup
#   npx openclaw gateway
# Then log into your AI provider(s) in the browser window.
# FREE access to Claude, ChatGPT, Gemini, DeepSeek, Grok, Qwen, and more.
#
# OPENCLAW_BASE_URL=http://localhost:18789
# OPENCLAW_MODEL=claude-sonnet-4-20250514
# OPENCLAW_TOKEN=            # Gateway auth token (if configured)

# ============================================================
# Ollama (local) — required when PROVIDER=ollama
# ============================================================
# Install: https://ollama.com/download
# Start:   ollama serve
# Pull:    ollama pull llama3.1:8b
#
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# ============================================================
# Google Gemini — required when PROVIDER=gemini
# ============================================================
# Get free API key: https://aistudio.google.com/app/apikey
#
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash

# ============================================================
# Free Multi-Provider — required when PROVIDER=free
# ============================================================
# Chains multiple free-tier APIs with automatic failover.
# Set as many keys as you have — more keys = more throughput.
# Get free keys (no credit card needed):
#
# GROQ_API_KEY=...        # 30 req/min  https://console.groq.com/keys
# GEMINI_API_KEY=...      # 15 req/min  https://aistudio.google.com/app/apikey
# CEREBRAS_API_KEY=...    # fast free   https://cloud.cerebras.ai/
# GITHUB_TOKEN=...        # free        https://github.com/settings/tokens

# ============================================================
# Workspace — path the agent operates in
# ============================================================
WORKSPACE=./backend
