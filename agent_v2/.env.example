# Add multiple API keys for automatic rotation.
# The agent will switch to the next key when one hits a rate limit.
ANTHROPIC_API_KEY_1=sk-ant-your-first-key-here
ANTHROPIC_API_KEY_2=sk-ant-your-second-key-here
ANTHROPIC_API_KEY_3=sk-ant-your-third-key-here

# Or use a single key (v1 compatible):
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Path to the workspace the agent operates in
WORKSPACE=./backend

# ── Hybrid Memory System ─────────────────────────────────────────────
# ChromaDB is optional — install with: pip install chromadb
# If not installed, semantic memory is disabled (all other memory works).
# Memory data is stored in agent_v2/data/ (auto-created).
